<%= turbo_frame_tag dom_id(article, "id") do %>
  <div class="p-4 border rounded-md shadow-md mb-4">
    <%= link_to article, "data-turbo-prefetch": false, "data-turbo-frame": :article_details, class: "" do %>
      <h2 class="text-xl font-bold"><%= article.title %></h2>
      <p class="text-gray-700"><%= article.content %></p>
      <span class="text-gray-700">Status:</span><span class="<%= article.viewed ? "text-green-500" : "text-red-500"  %>"><%= article.viewed ? "viewed" : "not viewed"  %></span>
    <% end %>
    <br>
    <%= link_to "Edit", edit_article_path(article), class: "text-blue-500 hover:underline" %>
    <%= link_to "Delete", article, method: :delete, data: { turbo_method: :delete, turbo_confirm: "are you sure" }, class: "text-red-500 hover:underline" %>
  </div>  
<% end %>